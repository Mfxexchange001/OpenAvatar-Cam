{
  "name": "openavatar-cam",
  "version": "1.0.0",
  "description": "Production-ready AI virtual webcam desktop application",
  "main": "./dist/main/main.js",
  "homepage": "./",
  "author": "OpenAvatar Team",
  "license": "MIT",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "dev": "concurrently \"yarn electron-dev\" \"yarn react-start\"",
    "electron-dev": "wait-on http://localhost:3000 && electron . --dev",
    "electron-build": "yarn react-build && electron-builder",
    "build": "yarn react-build && yarn build-electron",
    "build-electron": "tsc --project ./tsconfig.electron.json",
    "build-main": "tsc --project ./tsconfig.main.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.8",
    "@tensorflow/tfjs": "^4.11.0",
    "@tensorflow/tfjs-backend-webgl": "^4.11.0",
    "axios": "^1.6.0",
    "electron-is-dev": "^2.0.0",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0",
    "three": "^r158",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@electron/remote": "^2.1.2",
    "@types/electron": "^1.6.10",
    "@types/node": "^20.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.50.0",
    "react-scripts": "5.0.1",
    "typescript": "^5.2.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.openavatar.cam",
    "productName": "OpenAvatar Cam",
    "files": [
      "dist/",
      "node_modules/",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        "NSIS",
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.video"
    }
  }
}
